# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# Ruta del proyecto Flutter
flutter_application_path = File.expand_path('..', __dir__)

# Buscar la ruta real del SDK de Flutter en Codemagic/Mac
flutter_root = `flutter --version --machine | grep flutterRoot | sed -E 's/.*"flutterRoot":"([^"]+)".*/\1/'`.strip

# Incluir el podhelper desde el SDK de Flutter
require File.expand_path(File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper'))

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_ios_podfile_setup
end

post_install do |installer|
  flutter_additional_ios_build_settings(installer)
end
